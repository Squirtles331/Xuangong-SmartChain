# Router mode
VITE_ROUTER_MODE='history, /'

# Element Plus loading strategy
VITE_LOAD_ALL_EP_STYLE=true
VITE_LOAD_ALL_EP_COMPONENTS=true

# WebSocket URL
VITE_WEBSOCKET_URL=''

# Supported data mode: static / api
VITE_DATA_MODE=static
